OPENAI_API_KEY="YOUR_KEY_HERE"

# Use a model that supports Structured Outputs.
OPENAI_MODEL="gpt-5"
OPENAI_EMBED_MODEL="text-embedding-3-small"

# Where the SQLite KB lives
TS_DB_PATH="ts_kb_GOOGL_demo.sqlite3"

# For SEC downloads, set a descriptive UA string
SEC_USER_AGENT="Your Name (your.email@example.com)"

# Optional tuning
TS_MAX_CHUNKS=30
TS_LAMBDA_DECAY=0.002
TS_TAU_RELIABILITY_DAYS=365

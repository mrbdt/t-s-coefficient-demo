# This is an example .env file for the T-S Coefficient demo. the real .env file with my api keys etc. is on my local machine.

OPENAI_API_KEY=""

# models being used in the demo:
OPENAI_MODEL="gpt-5-mini"
OPENAI_EMBED_MODEL="text-embedding-3-small"

# Where the SQLite KB lives
TS_DB_PATH="data/output/ts_kb_GOOGL_demo.sqlite3"

# For SEC downloads, set a descriptive UA string
SEC_USER_AGENT="Name (my.email@example.com)"

# Optional tuning
TS_MAX_CHUNKS="maximum number of chunks to split a document into for claim extraction (default: 30)"
TS_LAMBDA_DECAY="decay rate for time-based reliability decay function (default: 0.002)"
TS_TAU_RELIABILITY_DAYS="tau parameter for reliability decay function in days (default: 365)"
